# Built binary (built into ~/.local/bin, but guard against a stray local build)
/assistant

# Go test caches and coverage
*.test
*.out
/coverage.txt

# Python bytecode from the helper venv scripts (gcal, rag, transcribe, …)
__pycache__/
*.pyc

# Local config & secrets — these should never be committed
/config.yaml
/secrets.env
*.local.yaml

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Runtime scheduler lock (not source)
.claude/scheduled_tasks.lock
