#!/usr/bin/env bash
# Google Calendar OAuth bootstrap — chat-driven and headless. Saves a refresh
# token the bridge then uses silently.
#
#   scripts/gcal-auth url                  # print a consent URL to send the user
#   scripts/gcal-auth exchange <code|url>  # exchange the pasted code/redirect URL
#   scripts/gcal-auth browser              # legacy local-browser flow (needs a display)
#
# Env: GCAL_VENV, GCAL_OAUTH_CLIENT (default ~/.config/assistant/gcal-oauth.json),
# GCAL_TOKEN (default ~/.config/assistant/gcal-token.json).

set -euo pipefail

VENV="${GCAL_VENV:-$HOME/.local/share/assistant/gcal-venv}"
here="$(cd "$(dirname "$0")" && pwd)"

if [[ ! -x "$VENV/bin/python" ]]; then
  echo "gcal venv missing at $VENV (run scripts/setup-gcal.sh)" >&2
  exit 1
fi

exec "$VENV/bin/python" "$here/gcal-auth.py" "$@"
