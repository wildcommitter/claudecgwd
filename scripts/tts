#!/usr/bin/env bash
# Synthesize speech from stdin text into an OGG/Opus voice note — the single
# entrypoint the bridge calls. Wraps the local piper venv + ffmpeg so callers
# don't need to know about either.
#
#   echo "hello there" | tts <output.ogg>
#
# Env overrides: TTS_VENV (default ~/.local/share/assistant/tts-venv),
# TTS_VOICE (default en_US-amy-medium), TTS_VOICES_DIR
# (default ~/.local/share/assistant/tts-voices).

set -euo pipefail

VENV="${TTS_VENV:-$HOME/.local/share/assistant/tts-venv}"
VOICE="${TTS_VOICE:-en_US-amy-medium}"
VOICES_DIR="${TTS_VOICES_DIR:-$HOME/.local/share/assistant/tts-voices}"

out="${1:?usage: tts <output.ogg> (text on stdin)}"

if [[ ! -x "$VENV/bin/piper" ]]; then
  echo "TTS venv missing at $VENV (run scripts/setup-tts.sh)" >&2
  exit 1
fi

# Download the voice model on demand if it isn't already present (so switching
# language via /speech just works). Voice name <lang>-<name>-<quality> maps to
# the piper-voices repo path <lang>/<region>/<name>/<quality>/<voice>.onnx.
mkdir -p "$VOICES_DIR"
if [[ ! -f "$VOICES_DIR/$VOICE.onnx" ]]; then
  region="${VOICE%%-*}"        # en_US
  lang="${region%%_*}"         # en
  rest="${VOICE#*-}"           # amy-medium
  name="${rest%%-*}"           # amy
  quality="${rest#*-}"         # medium
  base="https://huggingface.co/rhasspy/piper-voices/resolve/main/${lang}/${region}/${name}/${quality}/${VOICE}"
  echo "downloading voice $VOICE…" >&2
  for ext in onnx onnx.json; do
    curl -fsSL --retry 2 "$base.$ext" -o "$VOICES_DIR/$VOICE.$ext" || {
      echo "voice download failed: $VOICE.$ext" >&2
      rm -f "$VOICES_DIR/$VOICE.onnx" "$VOICES_DIR/$VOICE.onnx.json"
      exit 1
    }
  done
fi

wav="$(mktemp --suffix=.wav)"
trap 'rm -f "$wav"' EXIT

# piper reads text from stdin and writes a 22.05kHz mono WAV.
"$VENV/bin/piper" --model "$VOICES_DIR/$VOICE.onnx" --output_file "$wav" >/dev/null 2>&1

# Telegram voice notes and WhatsApp PTT both want OGG/Opus.
ffmpeg -y -loglevel error -i "$wav" -c:a libopus -b:a 32k -ar 48000 "$out"
