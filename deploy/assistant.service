[Unit]
Description=Personal Claude assistant (Telegram + WhatsApp bridge)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/assistant -config %h/.config/assistant/config.yaml
EnvironmentFile=%h/.config/assistant/secrets.env
Restart=always
RestartSec=5s
# Send stdout/stderr to journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
