# Copy this file to ~/.config/assistant/secrets.env and chmod 600 it.
# systemd's EnvironmentFile= reads KEY=VALUE pairs from here.

TELEGRAM_BOT_TOKEN=put-your-bot-token-here

# Google Calendar (optional). Drop the service-account JSON key at
# ~/.config/assistant/gcal-sa.json (or set GCAL_CREDENTIALS), share your
# calendar with the service account's client_email, and set GCAL_CALENDAR to
# your calendar id (your Gmail address for a personal calendar).
# GCAL_CALENDAR=you@gmail.com
# GCAL_CREDENTIALS=/home/user/.config/assistant/gcal-sa.json
