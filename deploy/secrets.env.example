# Copy this file to ~/.config/assistant/secrets.env and chmod 600 it.
# systemd's EnvironmentFile= reads KEY=VALUE pairs from here.

TELEGRAM_BOT_TOKEN=put-your-bot-token-here

# Google Calendar (optional, OAuth). Download your Desktop OAuth client JSON to
# ~/.config/assistant/gcal-oauth.json, run `scripts/gcal-auth` once (browser
# consent — stores a refresh token), and the bridge uses it thereafter.
# GCAL_CALENDAR defaults to "primary" (your own calendar); override to target a
# different one. Paths below only needed to override the defaults.
# GCAL_CALENDAR=primary
# GCAL_OAUTH_CLIENT=/home/user/.config/assistant/gcal-oauth.json
# GCAL_TOKEN=/home/user/.config/assistant/gcal-token.json
